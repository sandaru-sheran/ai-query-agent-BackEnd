UNI_DB_URL="mysql+pymysql://<your_db_username>:<your_db_password>@localhost:3306/ecommerce"
CONVERSATION_DB_URL="mysql+pymysql://<your_db_username>:<your_db_password>@localhost:3306/conversation"

# ==========================================
# LLM Provider Settings (LM Studio defaults)
# ==========================================
LLM_BASE_URL="http://127.0.0.1:1234/v1"
LLM_API_KEY="lm-studio"

# ==========================================
# Main AI Agent Configurations
